
@article{yang_simulation_2022,
	title = {Simulation of {Magnetic} {Resonance} {Sounding} {With} a {Delayed} {Adiabatic} {Pulse}},
	volume = {13},
	issn = {1949-3088},
	url = {https://ieeexplore.ieee.org/abstract/document/9850383},
	doi = {10.1109/LMAG.2022.3196597},
	abstract = {Magnetic resonance sounding (MRS) is used to identify groundwater by exciting and measuring the nuclear magnetic resonance of hydrogen nuclei in subsurface aquifers. However, the MRS response is particularly weak and has a low signal-to-noise ratio (SNR); therefore, signal enhancement methods, such as adiabatic pulses, are essential for MRS applications with strong interference. The key challenges of utilizing this novel method are to increase the MRS signal response and sensitivity for field measurements. In this letter, we present an improved transmitting mode of a commonly used adiabatic half-passage pulse by combining this pulse with an earlier fixed frequency off-resonant pulse of short duration, thereby increasing the theoretical MRS sensitivity. Simulation results demonstrate that the approach could be used to further improve the signal responses, i.e., in terms of the SNR and potential resolution, for MRS exploration of high-noise environments.},
	urldate = {2024-01-11},
	journal = {IEEE Magnetics Letters},
	author = {Yang, Benquan and Yang, Yujing},
	year = {2022},
	pages = {1--5},
	file = {IEEE Xplore Full Text PDF:/home/au617623/Zotero/storage/3RPQ2LLA/Yang and Yang - 2022 - Simulation of Magnetic Resonance Sounding With a D.pdf:application/pdf},
}

@article{larsen_efficient_2021,
	title = {Efficient processing of surface {NMR} data with spectral analysis},
	volume = {229},
	issn = {1365-246X},
	url = {https://ieeexplore.ieee.org/document/9684823},
	doi = {10.1093/gji/ggab472},
	abstract = {Due to its direct sensitivity to groundwater, surface nuclear magnetic resonance (NMR) is an intriguing, non-invasive geophysical technique. However, the surface NMR signal is inherently weak. In turn, the signal-to-noise ratio is often poor, and many signal processing steps must be used to improve it. One of the last processing steps is the extraction of the complex envelope of the NMR signal. This is normally done with synchronous detection, but a different method, spectral analysis was recently suggested, and it has shown promising results. Spectral analysis differs from synchronous detection, as it is a non-causal filtering method with a much narrower detection bandwidth and corresponding improved noise rejection. Until now, spectral analysis has not been applied to data sets acquired with commercially available equipment. We investigate the applicability and performance of spectral analysis on two data sets acquired with the two instruments on the market. The investigation is done with synthetic signals embedded in noise-only data and with field data. Our analysis reveals that spectral analysis is applicable for both instruments and leads to high-quality NMR envelopes. With a synthetic mono-exponential NMR signal embedded in noise-only data, we find that spectral analysis is better able to retrieve all NMR parameters. With field data, we find that the relative uncertainty on gated data is improved by a factor of 2{\textendash}4 in one data set and a factor of 4{\textendash}9 in a second data set. We invert both data sets, and show that spectral analysis leads to better-resolved models with lower model uncertainty.},
	number = {1},
	urldate = {2024-05-31},
	journal = {Geophysical Journal International},
	author = {Larsen, Jakob Juul and Langhof, Rasmus Balling and Kj{\ae}r, Martin Wohlert and Vang, Mathias and Liu, Lichao and Griffiths, Matthew and Grombacher, Denys},
	month = oct,
	year = {2021},
	note = {Conference Name: Geophysical Journal International},
	keywords = {Fourier analysis, Hydrogeophysics, Time-series analysis},
	pages = {286--298},
	file = {IEEE Xplore Abstract Record:/home/au617623/Zotero/storage/8K6X2LZS/9684823.html:text/html;Submitted Version:/home/au617623/Zotero/storage/QN8F82L3/Larsen et al. - 2021 - Efficient processing of surface NMR data with spec.pdf:application/pdf},
}


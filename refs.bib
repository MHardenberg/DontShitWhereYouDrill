	keywords = {adiabatic pulse, analytical solution, Bloch equation, HS pulse, hyperbolic secant},
	pages = {1630--1638},
	file = {Full Text PDF:/home/au617623/Zotero/storage/65Y2NVAH/Zhang et al. - 2017 - Full analytical solution of the bloch equation whe.pdf:application/pdf;Snapshot:/home/au617623/Zotero/storage/ZVIQM4DQ/mrm.html:text/html},

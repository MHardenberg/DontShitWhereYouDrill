@article{rasmussen_robust_2018,
	title = {Robust cancellation of minimum shift keying-encoded radio interference in data from the transient electromagnetic method},
	volume = {83},
	issn = {0016-8033, 1942-2156},
	url = {https://library.seg.org/doi/10.1190/geo2017-0611.1},
	doi = {10.1190/geo2017-0611.1},
	abstract = {Interference from radio signals in the very low frequency (VLF, 3{\textendash}30~kHz) band constitutes a significant part of the noise in data, measured using the transient electromagnetic method (TEM). Most radio signals in this frequency band convey streams of binary data, encoded using minimum shift keying or variants thereof. We have developed a framework for cancellation of these signals by modeling and subtracting the interfering signals from the recorded data. The framework uses several techniques to ensure robust and accurate modeling of the radio signals in a typical airborne TEM environment. These include combination of signals from multiple receiver coils, tracking of time-varying parameters for each receiver coil, use of a priori knowledge pertaining to the TEM primary field, and use of a high-performance decoding algorithm. Examples using recorded noise data from the field combined with synthetic TEM signals indicate a significant reduction in noise power. This results in a reduction of the standard deviation of approximately 1.5{\textendash}4 times in the early to intermediate-time response, after common processing steps have been applied. In the late-time part of the response, little to no improvement is seen. Although the attainable improvement in signal quality is highly case dependent, we expect that significant noise reduction can be achieved in most cases. Despite not being tested, our framework should be directly applicable in the low frequency (LF, 30{\textendash}300~kHz) band, which has relevance for wide-band systems.},
	language = {en},
	number = {2},
	urldate = {2025-02-07},
	journal = {GEOPHYSICS},
	author = {Rasmussen, S{\o}ren and Nyboe, Nicklas Skovgaard and Mai, Sune and Larsen, Jakob Juul},
	month = mar,
	year = {2018},
	pages = {E87--E94},
	file = {Full Text PDF:/home/au617623/Zotero/storage/QMUZTZMW/Rasmussen et al. - 2018 - Robust cancellation of minimum shift keying-encoded radio interference in data from the transient el.pdf:application/pdf},
}

